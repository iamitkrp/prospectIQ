# ============================================================
# ProspectIQ — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is git-ignored by default.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Required. Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Brevo (Email Sending) ────────────────────────────────────
# Required. Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_SENDER_EMAIL=you@yourdomain.com

# ── Groq AI (Email Generation) ───────────────────────────────
# Required. Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Upstash QStash (Campaign Scheduling) ─────────────────────
# Required. Get from: https://console.upstash.com → QStash → Details
QSTASH_TOKEN=your-qstash-token-here
QSTASH_CURRENT_SIGNING_KEY=sig_current-key-here
QSTASH_NEXT_SIGNING_KEY=sig_next-key-here

# ── App Configuration ────────────────────────────────────────
# Max emails per day (Brevo free tier = 300)
DAILY_SEND_LIMIT=300

# Internal secret for server-to-server campaign execution calls.
# Generate with: openssl rand -hex 32  (or any random 32+ char string)
CAMPAIGN_INTERNAL_SECRET=your-random-hex-secret

# Encryption key for securing user's SMTP App Passwords in the database.
# MUST BE EXACTLY 32 CHARACTERS LONG.
# Generate with: openssl rand -hex 16
SMTP_ENCRYPTION_KEY=your-32-character-encryption-key-here

# ── Public URLs (set in Vercel, optional locally) ─────────────
# VERCEL_URL is auto-provided by Vercel — no need to set it.
# NEXT_PUBLIC_APP_URL overrides VERCEL_URL for internal API calls.
# NEXT_PUBLIC_SITE_URL is used for OpenGraph meta tags.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
